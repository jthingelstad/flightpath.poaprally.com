---
layout: layout.njk
activeTab: home
pageTitle: Home
---

{%- set claimedCount = airports | claimedAirports | length -%}
{%- set totalAirports = airports | length -%}
{%- set claimedCountries = airports | claimedAirports | countUnique("country") -%}
{%- set pct = claimedCount | percentage(totalAirports) -%}
{%- set remaining = totalAirports - claimedCount -%}

<div class="page-scroll">

  <div class="home-hero">
    <div class="home-stat-card">
      <div class="home-stat-value">{{ claimedCount }} / {{ totalAirports }}</div>
      <div class="home-stat-label">airports claimed</div>
    </div>
    <div class="home-stat-card">
      <div class="home-stat-value">{{ claims | length }}</div>
      <div class="home-stat-label">total claims</div>
    </div>
    <div class="home-stat-card">
      <div class="home-stat-value">{{ leaderboards.addresses | length }}</div>
      <div class="home-stat-label">travelers</div>
    </div>
    <div class="home-stat-card">
      <div class="home-stat-value">{{ claimedCountries }}</div>
      <div class="home-stat-label">countries</div>
    </div>
  </div>

  <div class="home-completion">
    <div class="home-completion-bar">
      <div class="home-completion-fill" style="width: {{ pct }}%"></div>
    </div>
    <div class="home-completion-text">{{ pct }}% of airports claimed — {{ remaining }} remaining</div>
  </div>

  <div class="home-columns">
    <div class="home-column">
      <div class="home-section">
        <div class="home-section-header">
          <h2>Recent Activity</h2>
        </div>
        <div class="home-activity">
          {%- for c in claims | sortByCreatedDesc | limit(12) %}
            {%- set ap = airports | findByCode(c.airport) %}
            <a class="home-activity-row" href="/travelers/{{ c.address }}/">
              <span class="home-activity-date">{{ c.created | relativeDate }}</span>
              <span class="home-activity-traveler">{{ c.ens or (c.address | truncateAddress) }}</span>
              <span class="home-activity-arrow">&rarr;</span>
              <span class="home-activity-airport">
                <span class="home-activity-code">{{ c.airport }}</span>
                <span class="home-activity-city">{{ ap.city if ap else "" }}</span>
              </span>
            </a>
          {%- endfor %}
        </div>
      </div>
    </div>
    <div class="home-column">
      <div class="home-section">
        <div class="home-section-header">
          <h2>Top Travelers</h2>
          <a class="home-see-all" href="/travelers/">See all</a>
        </div>
        <table class="board-table board-table--compact">
          <thead>
            <tr>
              <th class="col-rank" scope="col">#</th>
              <th scope="col">Traveler</th>
              <th class="col-num" scope="col">Airports</th>
            </tr>
          </thead>
          <tbody>
            {%- for a in leaderboards.addresses | limit(5) %}
            <tr>
              <td><span class="board-rank">{{ loop.index }}</span></td>
              <td><a href="/travelers/{{ a.address }}/">
                {%- if a.ens %}<span class="board-ens">{{ a.ens }}</span>
                {%- else %}<span class="board-address">{{ a.address | truncateAddress }}</span>{% endif -%}
              </a></td>
              <td class="col-num"><span class="board-value board-value--highlight">{{ a.airport_count }}</span></td>
            </tr>
            {%- endfor %}
          </tbody>
        </table>
      </div>
      <div class="home-section">
        <div class="home-section-header">
          <h2>Top Airports</h2>
          <a class="home-see-all" href="/airports/">See all</a>
        </div>
        <table class="board-table board-table--compact">
          <thead>
            <tr>
              <th class="col-rank" scope="col">#</th>
              <th scope="col">Airport</th>
              <th class="col-num" scope="col">Claims</th>
            </tr>
          </thead>
          <tbody>
            {%- for a in leaderboards.airports | limit(5) %}
            <tr>
              <td><span class="board-rank">{{ loop.index }}</span></td>
              <td><a href="/airports/{{ a.code | lower }}/">
                <span class="board-airport-code">{{ a.code }}</span> {{ a.name }}
              </a></td>
              <td class="col-num"><span class="board-value board-value--highlight">{{ a.claims }}</span></td>
            </tr>
            {%- endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="home-section home-regions-section">
    <div class="home-section-header">
      <h2>Regions</h2>
    </div>
    <div class="home-regions">
      {%- for r in leaderboards.regions %}
        <div class="home-region-card">
          <div class="home-region-name">{{ r.continent }}</div>
          <div class="home-region-stats">
            <strong>{{ r.airport_count }}</strong> airports &middot;
            <strong>{{ r.claims }}</strong> claims
          </div>
        </div>
      {%- endfor %}
    </div>
  </div>

</div>
