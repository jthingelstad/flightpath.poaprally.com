---
layout: false
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Flight Path — POAP Airport Rally</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;600;700&family=Roboto+Mono:wght@400;500;700&family=Rubik:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://tinylytics.app/embed/wzwsuAffTZQwyzBouNms.js?events" defer></script>
</head>
<body>

  <!-- ============================================================
       Board View (default — full-page leaderboard)
       ============================================================ -->
  <div id="board-view" class="board-container">
    <header class="board-header">
      <div class="board-branding">
        <h1 class="board-title">Flight Path</h1>
        <span class="board-subtitle">POAP Airport Rally 2026</span>
      </div>
      <div class="board-stats">
        <span class="board-stat"><strong id="stat-airports">0</strong> airports</span>
        <span class="board-stat"><strong id="stat-claims">0</strong> claims</span>
        <span class="board-stat"><strong id="stat-travelers">0</strong> travelers</span>
      </div>
    </header>

    <nav class="board-tabs">
      <button class="board-tab active" data-tab="teams" data-tinylytics-event="tab.teams">Teams</button>
      <button class="board-tab" data-tab="travelers" data-tinylytics-event="tab.travelers">Travelers</button>
      <button class="board-tab" data-tab="airports" data-tinylytics-event="tab.airports">Airports</button>
      <button class="board-tab" data-tab="regions" data-tinylytics-event="tab.regions">Regions</button>
    </nav>

    <main class="board-content">
      <!-- Teams tab -->
      <div class="board-panel active" id="panel-teams">
        <div id="teams-list">
          <table class="board-table">
            <thead>
              <tr>
                <th class="col-rank">#</th>
                <th>Team</th>
                <th class="col-num">Members</th>
                <th class="col-num">Airports</th>
                <th class="col-num">Score</th>
              </tr>
            </thead>
            <tbody id="lb-teams"></tbody>
          </table>
        </div>
        <div id="teams-detail" style="display: none;">
          <button id="teams-back" class="board-back-btn" data-tinylytics-event="teams.back">&larr; All Teams</button>
          <div id="team-header"></div>
          <table class="board-table">
            <thead>
              <tr>
                <th class="col-rank">#</th>
                <th>Member</th>
                <th class="col-num">Airports</th>
              </tr>
            </thead>
            <tbody id="team-members"></tbody>
          </table>
        </div>
      </div>

      <!-- Travelers tab -->
      <div class="board-panel" id="panel-travelers">
        <div class="board-search">
          <input type="text" id="address-search" placeholder="Search address or ENS..." autocomplete="off">
          <button id="clear-search" class="board-search-clear" style="display: none;" data-tinylytics-event="search.clear">&times;</button>
        </div>
        <table class="board-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th>Address</th>
              <th class="col-num">Airports</th>
            </tr>
          </thead>
          <tbody id="lb-travelers"></tbody>
        </table>
      </div>

      <!-- Airports tab -->
      <div class="board-panel" id="panel-airports">
        <table class="board-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th>Airport</th>
              <th>City</th>
              <th>Region</th>
              <th class="col-num">Claims</th>
            </tr>
          </thead>
          <tbody id="lb-airports"></tbody>
        </table>
      </div>

      <!-- Regions tab -->
      <div class="board-panel" id="panel-regions">
        <table class="board-table">
          <thead>
            <tr>
              <th class="col-rank">#</th>
              <th>Region</th>
              <th class="col-num">Airports</th>
              <th class="col-num">Claims</th>
            </tr>
          </thead>
          <tbody id="lb-regions"></tbody>
        </table>
      </div>
    </main>

    <footer class="board-footer">
      <span class="board-updated">Updated {{ meta.last_updated | formatDate }}</span>
      <button id="globe-open" class="board-globe-btn" data-tinylytics-event="globe.open">
        <span class="globe-icon">&#127758;</span> View Globe
      </button>
      <a href="https://poap.xyz" target="_blank" rel="noopener" data-tinylytics-event="link.poap-xyz" class="board-link">poap.xyz</a>
    </footer>
  </div>

  <!-- ============================================================
       Globe View (hidden by default, lazy-loaded)
       ============================================================ -->
  <div id="globe-view" class="globe-view" style="display: none;">
    <div id="globe-container"></div>
    <div id="globe-tooltip" class="tooltip" style="display: none;"></div>

    <div class="overlay-title">
      <h1>Flight Path</h1>
      <p class="subtitle">POAP Airport Rally 2026</p>
    </div>

    <div class="overlay-globe-controls">
      <button id="globe-back" class="btn btn-glass" data-tinylytics-event="globe.close">&larr; Leaderboard</button>
      <button id="spin-toggle" class="btn btn-glass" aria-label="Pause rotation" data-tinylytics-event="globe.spin-toggle">Pause Spin</button>
    </div>

    <div class="overlay-controls">
      <div class="search-group">
        <input type="text" id="globe-search" placeholder="Search address or ENS..." autocomplete="off">
        <button id="globe-clear-search" class="btn btn-secondary" style="display: none;" data-tinylytics-event="search.clear">Clear</button>
      </div>
      <div class="playback-group" id="playback-controls" style="display: none;">
        <button id="play-btn" class="btn btn-primary" data-tinylytics-event="playback.toggle">Play</button>
        <label class="speed-label">
          Speed
          <input type="range" id="speed-slider" min="1" max="5" value="3">
        </label>
      </div>
    </div>
  </div>

  <!-- Hidden element for JS-driven event tracking -->
  <button id="tinylytics-tracker" aria-hidden="true" style="position:absolute;left:-9999px;"></button>

  <script>
    // Inject data at build time — avoids extra fetch calls
    const AIRPORTS = {{ airports | dump | safe }};
    const CLAIMS = {{ claims | dump | safe }};
    const LEADERBOARDS = {{ leaderboards | dump | safe }};
    const TEAMS = {{ teams | dump | safe }};
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
