<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ pageTitle or "Flight Path" }} — POAP Airport Rally</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;600;700&family=Roboto+Mono:wght@400;500;700&family=Rubik:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script src="https://tinylytics.app/embed/wzwsuAffTZQwyzBouNms.js?events" defer></script>
</head>
<body>

  <div class="app-shell">

    <header class="app-header">
      <div class="app-header-top">
        <div class="app-branding">
          <a href="/" class="app-title-link"><h1 class="app-title">Flight Path</h1></a>
          <span class="app-subtitle">POAP Airport Rally 2026</span>
        </div>
        <div class="app-stats">
          {%- set claimedCount = airports | claimedAirports | length -%}
          <span class="app-stat"><strong>{{ claimedCount }}/{{ airports | length }}</strong> airports</span>
          <span class="app-stat"><strong>{{ claims | length }}</strong> claims</span>
          <span class="app-stat"><strong>{{ leaderboards.addresses | length }}</strong> travelers</span>
        </div>
      </div>
      <nav class="app-tabs">
        <a class="app-tab{% if activeTab == 'home' %} active{% endif %}" href="/">Home</a>
        <a class="app-tab{% if activeTab == 'globe' %} active{% endif %}" href="/globe/">Globe</a>
        <a class="app-tab{% if activeTab == 'teams' %} active{% endif %}" href="/teams/">Teams</a>
        <a class="app-tab{% if activeTab == 'travelers' %} active{% endif %}" href="/travelers/">Travelers</a>
        <a class="app-tab{% if activeTab == 'airports' %} active{% endif %}" href="/airports/">Airports</a>
        <a class="app-tab{% if activeTab == 'gauges' %} active{% endif %}" href="/gauges/">Gauges</a>
      </nav>
    </header>

    <main class="app-content">
      {{ content | safe }}
    </main>

    <footer class="app-footer{% if activeTab == 'globe' %} hidden{% endif %}">
      <span class="app-updated">Updated {{ meta.last_updated | formatDate }}</span>
      <a href="https://poap.xyz" target="_blank" rel="noopener" class="app-link">poap.xyz</a>
    </footer>

  </div>

  {{ extraScripts | safe }}
</body>
</html>
