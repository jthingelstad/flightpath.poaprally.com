---
layout: layout.njk
activeTab: globe
pageTitle: Globe
permalink: /globe/index.html
extraScripts: |
  <script>
    const AIRPORTS = {{ airports | dump | safe }};
    const CLAIMS = {{ claims | dump | safe }};
    const LEADERBOARDS = {{ leaderboards | dump | safe }};
  </script>
  <script src="/js/globe.js"></script>
---

<div class="tab-panel--globe active-globe">
  <div id="globe-container"></div>
  <div id="globe-tooltip" class="tooltip" style="display: none;"></div>

  <div class="globe-controls-top">
    <button id="spin-toggle" class="btn btn-glass" aria-label="Pause rotation">Pause Spin</button>
  </div>

  <div class="globe-controls-bottom">
    <div class="search-group">
      <input type="text" id="globe-search" placeholder="Search address or ENS..." autocomplete="off">
      <button id="globe-clear-search" class="btn btn-secondary" style="display: none;">Clear</button>
    </div>
    <div class="playback-group" id="playback-controls" style="display: none;">
      <button id="play-btn" class="btn btn-primary">Play</button>
      <label class="speed-label">
        Speed
        <input type="range" id="speed-slider" min="1" max="5" value="3">
      </label>
    </div>
  </div>
</div>
